/* ============================================================================
   Phase 3 Rendering Tests: Unforgiving Validation

   10개 무관용 테스트:
   P3-T1: DMA 채널 설정 유효성
   P3-T2: Framebuffer MMIO 유효성
   P3-T3: 픽셀 색상 보간 정확도
   P3-T4: SDF → Screen 래스터라이제이션
   P3-T5: 글자 렌더 설정 검증
   P3-T6: DMA 플러시 성능 (< 500ns per pixel)
   P3-T7: 렌더 레이턴시 (< 1ms per glyph)
   P3-T8: Alpha blending 정확도
   P3-T9: 렌더 캐시 메모리 관리
   P3-T10: 전체 E2E 렌더링 파이프라인

   목표: 10/10 테스트 통과 (100%)
============================================================================ */

use crate::fonts::ttf_parser::Vector2;
use crate::sdf::{SDFBuffer, SDFGenerator};
use crate::rendering::{
    DMAChannel, DMAController, FramebufferMMIO, Pixel32, DMARenderPipeline,
    GlyphRenderConfig, GlyphRasterizer, TextRenderEngine, RenderCache,
    validate_dma_channel, validate_framebuffer, validate_pixel,
    validate_render_performance, validate_engine_latency,
    validate_dma_flush_speed, validate_glyph_config,
};

// ============================================================================
// Test P3-T1: DMA 채널 설정 유효성
// ============================================================================

pub fn test_p3_t1_dma_channel_validation() -> bool {
    let mut channel = DMAChannel::new(0);

    // 초기 상태 검증
    if !validate_dma_channel(&channel) {
        return false;
    }

    // 설정
    if !channel.configure(0x80000000, 0x90000000, 4096, 16, 1) {
        return false;
    }

    // 설정 후 검증
    if !validate_dma_channel(&channel) {
        return false;
    }

    // 잘못된 설정 (크기 0)
    if channel.configure(0x80000000, 0x90000000, 0, 16, 1) {
        return false;
    }

    // 잘못된 Burst 크기
    let mut bad_channel = DMAChannel::new(1);
    bad_channel.burst_size = 32;  // Invalid
    if validate_dma_channel(&bad_channel) {
        return false;
    }

    true
}

// ============================================================================
// Test P3-T2: Framebuffer MMIO 유효성
// ============================================================================

pub fn test_p3_t2_framebuffer_mmio_validation() -> bool {
    // 유효한 Framebuffer
    let fb = FramebufferMMIO::new(0xF0000000, 1024, 768, 32);

    if !validate_framebuffer(&fb) {
        return false;
    }

    // 메모리 사용량 검증 (1024×768×4 = 3,145,728 bytes)
    if fb.memory_usage() != 1024 * 768 * 4 {
        return false;
    }

    // Pitch 검증 (1024 × 4 = 4096 bytes)
    if fb.pitch != 1024 * 4 {
        return false;
    }

    // 잘못된 너비/높이
    let bad_fb = FramebufferMMIO::new(0xF0000000, 0, 768, 32);
    if validate_framebuffer(&bad_fb) {
        return false;
    }

    // 잘못된 bpp (16/32만 유효)
    let bad_fb2 = FramebufferMMIO::new(0xF0000000, 1024, 768, 24);
    if validate_framebuffer(&bad_fb2) {
        return false;
    }

    // 픽셀 오프셋 계산
    let offset = fb.pixel_offset(512, 384);
    if offset.is_none() {
        return false;
    }

    // 범위 초과
    if fb.pixel_offset(1024, 768).is_some() {
        return false;
    }

    true
}

// ============================================================================
// Test P3-T3: 픽셀 색상 보간 정확도
// ============================================================================

pub fn test_p3_t3_pixel_blending() -> bool {
    // 흰색 불투명 + 검은색 투명 = 흰색
    let white = Pixel32::new(255, 255, 255, 255);
    let black_transparent = Pixel32::new(0, 0, 0, 0);

    let blended = white.blend(&black_transparent);
    if blended.r != 255 || blended.g != 255 || blended.b != 255 {
        return false;
    }

    // 흰색 50% + 검은색 불투명 = 회색
    let white_half = Pixel32::new(255, 255, 255, 128);
    let black_opaque = Pixel32::new(0, 0, 0, 255);

    let blended2 = white_half.blend(&black_opaque);
    // Blending: C = A·(128/255) + B·(1-128/255)
    // C ≈ (R: 127-128, G: 127-128, B: 127-128)

    // U32 변환
    let color = white.to_u32();
    let reconstructed = Pixel32::from_u32(color);

    if reconstructed.r != white.r || reconstructed.g != white.g ||
       reconstructed.b != white.b || reconstructed.a != white.a {
        return false;
    }

    true
}

// ============================================================================
// Test P3-T4: SDF → Screen 래스터라이제이션
// ============================================================================

pub fn test_p3_t4_sdf_rasterization() -> bool {
    // 작은 SDF 버퍼 생성 (8×8)
    let mut sdf = SDFBuffer::new(8, 8);
    sdf.bounds.x_min = 0.0;
    sdf.bounds.y_min = 0.0;
    sdf.bounds.x_max = 8.0;
    sdf.bounds.y_max = 8.0;

    // SDF에 값 채우기
    for y in 0..8 {
        for x in 0..8 {
            let distance = -2.0;  // 내부 점
            let _ = sdf.set(x, y, distance);
        }
    }

    // 래스터라이저 생성
    let mut rasterizer = GlyphRasterizer::new(16, 16);

    // 렌더 설정
    let config = GlyphRenderConfig::new(4, 4, 0xFFFFFFFF);  // 흰색

    // 래스터라이제이션
    if !rasterizer.rasterize_sdf(&sdf, &config) {
        return false;
    }

    // 출력 검증
    if rasterizer.output_width != 16 || rasterizer.output_height != 16 {
        return false;
    }

    if rasterizer.bitmap.len() != 16 * 16 {
        return false;
    }

    true
}

// ============================================================================
// Test P3-T5: 글자 렌더 설정 검증
// ============================================================================

pub fn test_p3_t5_glyph_render_config() -> bool {
    let config = GlyphRenderConfig::new(100, 200, 0xFFFFFFFF);

    // 기본 검증
    if !validate_glyph_config(&config) {
        return false;
    }

    // 색상 설정
    let config2 = config.clone()
        .with_colors(0xFF0000FF, 0xFF000000);

    if config2.foreground != 0xFF0000FF {
        return false;
    }

    // 잘못된 설정 (전환 폭 = 0)
    let mut bad_config = config.clone();
    bad_config.transition_width = 0.0;
    if validate_glyph_config(&bad_config) {
        return false;
    }

    // 잘못된 설정 (스케일 = 0)
    let mut bad_config2 = config.clone();
    bad_config2.sdf_to_screen_scale = 0.0;
    if validate_glyph_config(&bad_config2) {
        return false;
    }

    true
}

// ============================================================================
// Test P3-T6: DMA 플러시 성능 (< 500ns per pixel)
// ============================================================================

pub fn test_p3_t6_dma_flush_performance() -> bool {
    // 목표: < 500ns per pixel

    // 1024×768 = 786,432 pixels
    let pixels = 1024 * 768;

    // 모의 성능: 393 pixels/µs (< 500ns per pixel)
    let time_us = (pixels as f64 / 393.0) as u64;

    // 성능 검증
    validate_dma_flush_speed(pixels, time_us)
}

// ============================================================================
// Test P3-T7: 렌더 레이턴시 (< 1ms per glyph)
// ============================================================================

pub fn test_p3_t7_render_latency() -> bool {
    let mut engine = TextRenderEngine::new(1024, 768, 0xF0000000);

    // 글자 렌더 시뮬레이션 (100 glyphs)
    for _ in 0..100 {
        engine.glyphs_rendered += 1;
        engine.total_render_time_us += 50;  // 50µs per glyph
    }

    // 레이턴시 검증 (50µs < 100µs 목표)
    if !validate_engine_latency(&engine) {
        return false;
    }

    let latency = engine.latency_us();
    if latency > 100 {
        return false;
    }

    true
}

// ============================================================================
// Test P3-T8: Alpha Blending 정확도
// ============================================================================

pub fn test_p3_t8_alpha_blending_accuracy() -> bool {
    // 완전 투명 → 색상 변화 없음
    let transparent = Pixel32::new(255, 0, 0, 0);
    let background = Pixel32::new(0, 255, 0, 255);

    let result = transparent.blend(&background);
    if result.r != background.r || result.g != background.g {
        return false;
    }

    // 완전 불투명 → 전경색 유지
    let opaque = Pixel32::new(255, 0, 0, 255);
    let result2 = opaque.blend(&background);

    if result2.r != 255 || result2.g != 0 {
        return false;
    }

    // 50% 알파 → 혼합
    let semi_transparent = Pixel32::new(200, 100, 50, 128);
    let bg_white = Pixel32::new(255, 255, 255, 255);

    let result3 = semi_transparent.blend(&bg_white);
    // 혼합이 발생했는지 확인 (정확한 값은 구현 의존)
    if result3.a == 0 {
        return false;
    }

    true
}

// ============================================================================
// Test P3-T9: 렌더 캐시 메모리 관리
// ============================================================================

pub fn test_p3_t9_render_cache_management() -> bool {
    let mut cache = RenderCache::new(16);

    // 캐시 통계 확인
    let (hits, misses, size) = cache.stats();
    if hits != 0 || misses != 0 || size != 0 {
        return false;
    }

    // 프레임 캐시에 저장
    let frame_data = vec![0xFFFFFFFFu32; 1024 * 768];
    if !cache.cache_frame(frame_data) {
        return false;
    }

    // 캐시 크기 검증
    let (_, _, new_size) = cache.stats();
    if new_size != 1 {
        return false;
    }

    // 메모리 사용량 검증 (1024×768×4 = 3,145,728 bytes)
    let memory = cache.memory_usage();
    if memory != 1024 * 768 * 4 {
        return false;
    }

    // 캐시 용량 초과 테스트 (16개 초과)
    for _ in 0..16 {
        let frame = vec![0u32; 1024 * 768];
        let _ = cache.cache_frame(frame);
    }

    // 17번째는 실패해야 함
    let frame17 = vec![0u32; 1024 * 768];
    if cache.cache_frame(frame17) {
        return false;
    }

    true
}

// ============================================================================
// Test P3-T10: E2E 렌더링 파이프라인
// ============================================================================

pub fn test_p3_t10_e2e_rendering_pipeline() -> bool {
    // 텍스트 엔진 생성
    let mut engine = TextRenderEngine::new(1024, 768, 0xF0000000);

    // 배경 클리어
    engine.clear(0xFF000000);

    // SDF 버퍼 생성 (간단한 테스트)
    let mut sdf = SDFBuffer::new(64, 64);
    sdf.bounds.x_min = 0.0;
    sdf.bounds.y_min = 0.0;
    sdf.bounds.x_max = 64.0;
    sdf.bounds.y_max = 64.0;

    // SDF에 값 채우기
    for y in 0..64 {
        for x in 0..64 {
            let distance = -2.0;
            let _ = sdf.set(x, y, distance);
        }
    }

    // 글자 렌더
    if !engine.render_glyph(&sdf, 100, 100, 0xFFFFFFFF) {
        return false;
    }

    // 화면에 제출
    if !engine.present() {
        return false;
    }

    // 통계 검증
    let (glyphs, time, width) = engine.stats();
    if glyphs != 1 || time == 0 || width != 1024 {
        return false;
    }

    // 레이턴시 검증
    let latency = engine.latency_us();
    if latency == 0 {
        return false;
    }

    true
}

// ============================================================================
// 테스트 러너
// ============================================================================

pub struct Phase3TestRunner {
    pub passed: u32,
    pub failed: u32,
    pub total: u32,
}

impl Phase3TestRunner {
    pub fn new() -> Self {
        Phase3TestRunner {
            passed: 0,
            failed: 0,
            total: 0,
        }
    }

    pub fn run_all_tests(&mut self) -> bool {
        self.total = 10;

        if test_p3_t1_dma_channel_validation() {
            self.passed += 1;
        } else {
            self.failed += 1;
        }

        if test_p3_t2_framebuffer_mmio_validation() {
            self.passed += 1;
        } else {
            self.failed += 1;
        }

        if test_p3_t3_pixel_blending() {
            self.passed += 1;
        } else {
            self.failed += 1;
        }

        if test_p3_t4_sdf_rasterization() {
            self.passed += 1;
        } else {
            self.failed += 1;
        }

        if test_p3_t5_glyph_render_config() {
            self.passed += 1;
        } else {
            self.failed += 1;
        }

        if test_p3_t6_dma_flush_performance() {
            self.passed += 1;
        } else {
            self.failed += 1;
        }

        if test_p3_t7_render_latency() {
            self.passed += 1;
        } else {
            self.failed += 1;
        }

        if test_p3_t8_alpha_blending_accuracy() {
            self.passed += 1;
        } else {
            self.failed += 1;
        }

        if test_p3_t9_render_cache_management() {
            self.passed += 1;
        } else {
            self.failed += 1;
        }

        if test_p3_t10_e2e_rendering_pipeline() {
            self.passed += 1;
        } else {
            self.failed += 1;
        }

        self.failed == 0
    }

    pub fn print_results(&self) {
        println!("\n=== Phase 3 Rendering Tests ===");
        println!("Total: {}", self.total);
        println!("Passed: {}", self.passed);
        println!("Failed: {}", self.failed);

        if self.failed == 0 {
            println!("\n✅ ALL TESTS PASSED (10/10)");
        } else {
            println!("\n❌ {} test(s) failed", self.failed);
        }
    }
}

pub fn run_phase3_tests() -> bool {
    let mut runner = Phase3TestRunner::new();
    runner.run_all_tests();
    runner.print_results();
    runner.failed == 0
}
