/* ============================================================================
   Phase 1: Font Parser Tests (P1-T1 ~ P1-T10)

   목표: TTF 파싱 정확도 100%, 256 glyph < 100ms, 메모리 누수 = 0
============================================================================ */

use crate::fonts::ttf_parser::*;
use crate::fonts::glyph_data::*;

// ============================================================================
// Test Group P1: TTF Parser Validation (10개)
// ============================================================================

// P1-T1: TTF 헤더 매직 넘버 검증
pub fn test_p1_t1_ttf_header_magic() -> (bool, &'static str) {
    // 정상 TTF 헤더 시뮬레이션
    let mut data = vec![0u8; 1024];

    // 매직 넘버 설정: 0x00010000
    data[0] = 0x00;
    data[1] = 0x01;
    data[2] = 0x00;
    data[3] = 0x00;

    // 테이블 수: 10
    data[4] = 0x00;
    data[5] = 0x0A;

    let mut parser = TTFParser::new(data);

    if !parser.parse_header() {
        return (false, "P1-T1: Failed to parse header");
    }

    if let Some(header) = &parser.header {
        if header.version != 0x00010000 {
            return (false, "P1-T1: Magic number mismatch");
        }

        if header.num_tables != 10 {
            return (false, "P1-T1: Table count mismatch");
        }

        (true, "P1-T1: ✅ TTF header magic number validated (0x00010000)")
    } else {
        (false, "P1-T1: Header not parsed")
    }
}

// P1-T2: 테이블 디렉토리 파싱
pub fn test_p1_t2_table_directory() -> (bool, &'static str) {
    let mut data = vec![0u8; 2048];

    // TTF 헤더
    data[0] = 0x00; data[1] = 0x01; data[2] = 0x00; data[3] = 0x00;
    data[4] = 0x00; data[5] = 0x03;  // 3 tables

    // 테이블 레코드 1: 'head'
    data[12] = b'h'; data[13] = b'e'; data[14] = b'a'; data[15] = b'd';
    data[16] = 0x12; data[17] = 0x34; data[18] = 0x56; data[19] = 0x78;  // checksum
    data[20] = 0x00; data[21] = 0x00; data[22] = 0x00; data[23] = 0x36;  // offset = 54
    data[24] = 0x00; data[25] = 0x00; data[26] = 0x00; data[27] = 0x54;  // length = 84

    // 테이블 레코드 2: 'glyf'
    data[28] = b'g'; data[29] = b'l'; data[30] = b'y'; data[31] = b'f';
    data[32] = 0xAB; data[33] = 0xCD; data[34] = 0xEF; data[35] = 0x00;
    data[36] = 0x00; data[37] = 0x00; data[38] = 0x01; data[39] = 0x00;  // offset = 256
    data[40] = 0x00; data[41] = 0x00; data[42] = 0x10; data[43] = 0x00;  // length = 4096

    // 테이블 레코드 3: 'loca'
    data[44] = b'l'; data[45] = b'o'; data[46] = b'c'; data[47] = b'a';
    data[48] = 0x11; data[49] = 0x22; data[50] = 0x33; data[51] = 0x44;
    data[52] = 0x00; data[53] = 0x00; data[54] = 0x11; data[55] = 0x00;  // offset = 4352
    data[56] = 0x00; data[57] = 0x00; data[58] = 0x02; data[59] = 0x00;  // length = 512

    let mut parser = TTFParser::new(data);

    if !parser.parse_header() {
        return (false, "P1-T2: Failed to parse header");
    }

    if !parser.parse_table_directory() {
        return (false, "P1-T2: Failed to parse table directory");
    }

    if parser.table_records.len() != 3 {
        return (false, "P1-T2: Expected 3 tables");
    }

    // 'glyf' 테이블 검증
    if parser.glyf_offset != 256 {
        return (false, "P1-T2: glyf offset mismatch");
    }

    if parser.loca_offset != 4352 {
        return (false, "P1-T2: loca offset mismatch");
    }

    (true, "P1-T2: ✅ Table directory parsed correctly (3 tables, glyf/loca found)")
}

// P1-T3: 메타데이터 파싱 (head, maxp 테이블)
pub fn test_p1_t3_metadata_parsing() -> (bool, &'static str) {
    let mut data = vec![0u8; 4096];

    // TTF 헤더
    data[0] = 0x00; data[1] = 0x01; data[2] = 0x00; data[3] = 0x00;
    data[4] = 0x00; data[5] = 0x02;  // 2 tables

    // 테이블 레코드 1: 'head' (offset 36)
    data[12] = b'h'; data[13] = b'e'; data[14] = b'a'; data[15] = b'd';
    data[16] = 0x00; data[17] = 0x00; data[18] = 0x00; data[19] = 0x00;
    data[20] = 0x00; data[21] = 0x00; data[22] = 0x00; data[23] = 0x24;  // offset = 36
    data[24] = 0x00; data[25] = 0x00; data[26] = 0x00; data[27] = 0x54;

    // 테이블 레코드 2: 'maxp' (offset 120)
    data[28] = b'm'; data[29] = b'a'; data[30] = b'x'; data[31] = b'p';
    data[32] = 0x00; data[33] = 0x00; data[34] = 0x00; data[35] = 0x00;
    data[36] = 0x00; data[37] = 0x00; data[38] = 0x00; data[39] = 0x78;  // offset = 120
    data[40] = 0x00; data[41] = 0x00; data[42] = 0x00; data[43] = 0x20;

    // head 테이블 (offset 36)
    // units_per_em at offset 36 + 18 = 54
    data[54] = 0x07; data[55] = 0xD0;  // 2000 (units per em)

    // maxp 테이블 (offset 120)
    // num_glyphs at offset 120 + 4 = 124
    data[124] = 0x01; data[125] = 0x00;  // 256 (glyphs)

    let mut parser = TTFParser::new(data);

    if !parser.parse_header() {
        return (false, "P1-T3: Failed to parse header");
    }

    if !parser.parse_table_directory() {
        return (false, "P1-T3: Failed to parse table directory");
    }

    if !parser.parse_head_table() {
        return (false, "P1-T3: Failed to parse head table");
    }

    if !parser.parse_maxp_table() {
        return (false, "P1-T3: Failed to parse maxp table");
    }

    if parser.units_per_em != 2000 {
        return (false, "P1-T3: units_per_em mismatch");
    }

    if parser.num_glyphs != 256 {
        return (false, "P1-T3: num_glyphs mismatch");
    }

    (true, "P1-T3: ✅ Metadata parsed (units_per_em=2000, glyphs=256)")
}

// P1-T4: 글자 오프셋 계산 (loca 테이블)
pub fn test_p1_t4_glyph_offset_calculation() -> (bool, &'static str) {
    let mut data = vec![0u8; 4096];

    // TTF 헤더
    data[0] = 0x00; data[1] = 0x01; data[2] = 0x00; data[3] = 0x00;
    data[4] = 0x00; data[5] = 0x01;  // 1 table

    // 테이블 레코드: 'maxp'
    data[12] = b'm'; data[13] = b'a'; data[14] = b'x'; data[15] = b'p';
    data[16] = 0x00; data[17] = 0x00; data[18] = 0x00; data[19] = 0x00;
    data[20] = 0x00; data[21] = 0x00; data[22] = 0x00; data[23] = 0x00;  // offset
    data[24] = 0x00; data[25] = 0x00; data[26] = 0x00; data[27] = 0x20;

    // maxp 테이블 (offset 0)
    data[4] = 0x00; data[5] = 0x04;  // 4 glyphs

    let mut parser = TTFParser::new(data);
    parser.parse_header().ok();
    parser.parse_table_directory().ok();
    parser.num_glyphs = 4;
    parser.loca_offset = 200;

    // loca 테이블 모의 설정 (glyph 오프셋)
    // glyph 0: offset 0
    // glyph 1: offset 100
    // glyph 2: offset 200
    // glyph 3: offset 300
    data[200] = 0x00; data[201] = 0x00; data[202] = 0x00; data[203] = 0x00;
    data[204] = 0x00; data[205] = 0x00; data[206] = 0x00; data[207] = 0x64;  // 100
    data[208] = 0x00; data[209] = 0x00; data[210] = 0x00; data[211] = 0xC8;  // 200
    data[212] = 0x00; data[213] = 0x00; data[214] = 0x01; data[215] = 0x2C;  // 300

    if let Some(offset0) = parser.get_glyph_offset(0) {
        if offset0 != 0 {
            return (false, "P1-T4: Glyph 0 offset mismatch");
        }
    } else {
        return (false, "P1-T4: Failed to get glyph 0 offset");
    }

    if let Some(offset1) = parser.get_glyph_offset(1) {
        if offset1 != 100 {
            return (false, "P1-T4: Glyph 1 offset mismatch");
        }
    } else {
        return (false, "P1-T4: Failed to get glyph 1 offset");
    }

    if let Some(_offset) = parser.get_glyph_offset(4) {
        return (false, "P1-T4: Should not get offset for glyph 4 (out of range)");
    }

    (true, "P1-T4: ✅ Glyph offsets calculated correctly (0, 100, 200, 300)")
}

// P1-T5: 메모리 사용량 검증
pub fn test_p1_t5_memory_usage() -> (bool, &'static str) {
    let store = GlyphStore::new(256, 1000);

    let memory = store.memory_usage();

    // 256 glyph × (64 base + 0 curves avg) + map overhead
    // ~20KB 정도 예상
    if memory > 1024 * 1024 {
        return (false, "P1-T5: Memory usage too high");
    }

    if !store.validate_memory() {
        return (false, "P1-T5: Memory validation failed");
    }

    (true, "P1-T5: ✅ Memory usage < 1MB (validated)")
}

// P1-T6: 글자 데이터 구조 초기화
pub fn test_p1_t6_glyph_data_init() -> (bool, &'static str) {
    let glyph = GlyphData::new(0);

    if glyph.metrics.glyph_id != 0 {
        return (false, "P1-T6: Glyph ID mismatch");
    }

    if glyph.curves.len() != 0 {
        return (false, "P1-T6: Curves should be empty");
    }

    if !glyph.is_composite {
        // 정상
    } else {
        return (false, "P1-T6: Should not be composite");
    }

    (true, "P1-T6: ✅ GlyphData initialized correctly")
}

// P1-T7: 변환 행렬 적용
pub fn test_p1_t7_transform_matrix() -> (bool, &'static str) {
    let mut glyph = GlyphData::new(0);

    // 스케일 2×
    glyph.transform = TransformMatrix::scale(2.0, 2.0);

    let point = Vector2::new(1.0, 2.0);
    let transformed = glyph.transform.apply(&point);

    if (transformed.x - 2.0).abs() > 0.001 {
        return (false, "P1-T7: X scale mismatch");
    }

    if (transformed.y - 4.0).abs() > 0.001 {
        return (false, "P1-T7: Y scale mismatch");
    }

    (true, "P1-T7: ✅ Transform matrix applied correctly (2x scale)")
}

// P1-T8: 경계상자 계산
pub fn test_p1_t8_bounding_box() -> (bool, &'static str) {
    let bounds = BoundingBox::new(10.0, 20.0, 100.0, 120.0);

    if bounds.width() != 90.0 {
        return (false, "P1-T8: Width mismatch");
    }

    if bounds.height() != 100.0 {
        return (false, "P1-T8: Height mismatch");
    }

    if bounds.area() != 9000.0 {
        return (false, "P1-T8: Area mismatch");
    }

    if !bounds.contains_point(50.0, 70.0) {
        return (false, "P1-T8: Point should be inside bounds");
    }

    if bounds.contains_point(200.0, 200.0) {
        return (false, "P1-T8: Point should be outside bounds");
    }

    (true, "P1-T8: ✅ Bounding box calculations correct")
}

// P1-T9: Unicode 매핑
pub fn test_p1_t9_unicode_mapping() -> (bool, &'static str) {
    let mut store = GlyphStore::new(256, 1000);

    // 'A' (U+0041) -> glyph 1
    store.add_unicode_mapping(0x0041, 1);

    // 'B' (U+0042) -> glyph 2
    store.add_unicode_mapping(0x0042, 2);

    if store.unicode_map.len() != 2 {
        return (false, "P1-T9: Unicode map size mismatch");
    }

    if let Some(glyph) = store.get_glyph_by_unicode(0x0041) {
        if glyph.metrics.glyph_id != 1 {
            return (false, "P1-T9: Unicode 'A' maps to wrong glyph");
        }
    } else {
        return (false, "P1-T9: Failed to find Unicode 'A'");
    }

    (true, "P1-T9: ✅ Unicode mapping working (A->1, B->2)")
}

// P1-T10: 검증 함수 테스트
pub fn test_p1_t10_validation() -> (bool, &'static str) {
    let store = GlyphStore::new(256, 1000);

    if !validate_glyph_data(&store) {
        return (false, "P1-T10: Validation failed");
    }

    // NaN 값으로 오염된 glyph 추가
    let mut bad_store = GlyphStore::new(2, 1000);
    let mut glyph = GlyphData::new(0);
    glyph.curves.push(QuadraticBezier {
        p0: Vector2::new(f32::NAN, 0.0),
        p1: Vector2::new(0.0, 0.0),
        p2: Vector2::new(0.0, 0.0),
    });
    bad_store.glyphs[0] = glyph;

    if validate_glyph_data(&bad_store) {
        return (false, "P1-T10: Should reject NaN values");
    }

    (true, "P1-T10: ✅ Validation detects errors (NaN rejection)")
}

// ============================================================================
// 테스트 러너
// ============================================================================

pub fn run_phase1_tests() -> (u32, u32) {
    let tests = vec![
        test_p1_t1_ttf_header_magic(),
        test_p1_t2_table_directory(),
        test_p1_t3_metadata_parsing(),
        test_p1_t4_glyph_offset_calculation(),
        test_p1_t5_memory_usage(),
        test_p1_t6_glyph_data_init(),
        test_p1_t7_transform_matrix(),
        test_p1_t8_bounding_box(),
        test_p1_t9_unicode_mapping(),
        test_p1_t10_validation(),
    ];

    let mut passed = 0u32;
    let mut failed = 0u32;

    for (msg, status) in &tests {
        if *status {
            passed += 1;
        } else {
            failed += 1;
        }
        println!("{}", msg);
    }

    println!("\n========================================");
    println!("Phase 1 Results: {}/{} passed", passed, tests.len());
    println!("========================================\n");

    (passed, failed)
}
